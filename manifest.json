{
  "manifest_version": 2,
  "name": "Claude Intercepter",
  "version": "0.1.0",
  "description": "Route claude.ai inference through your own LiteLLM proxy",
  "permissions": [
    "storage",
    "cookies",
    "*://claude.ai/*",
    "https://proxy-ns-0ffzk4u2.usw-1.sealos.app/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": ["inject.js"],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-intercepter@sertdev",
      "strict_min_version": "140.0"
    }
  }
}
